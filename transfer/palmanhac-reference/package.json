{
  "name": "palmanhac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --cache --write \"**/*.{ts,tsx,js,jsx,cts,mts,json,md,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "postinstall": "prisma generate",
    "export-structure": "node --experimental-modules exportStructure.js",
    "export:aygoot-reference": "node scripts/export-aygoot-reference.mjs",
    "make:admin": "ts-node --esm -r tsconfig-paths/register scripts/create-admin.ts"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^5.19.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.1.6",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.4.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^11.3.30",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.461.0",
    "nanoid": "^5.0.7",
    "next": "16.0.7",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "stripe": "^19.3.1",
    "tailwind-merge": "^2.5.3",
    "zod": "^4.1.12",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prisma": "^5.19.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "ts-node --esm -r tsconfig-paths/register lib/data/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@auth/core": "0.41.1"
    }
  }
}
